// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Nand(a=a , b=a , out=notA );
    Nand(a=b , b=b , out=notB );
    And(a=a , b=notB , out=or1 );
    And(a=b , b=notA , out=or2 );
    Or(a=or1 , b=or2 , out=out );

}